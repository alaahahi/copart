# SQLite local / empty-project profile (Phase 1)
# Copy to .env OR temporarily override without touching MySQL .env:
#
#   Windows PowerShell:
#     $env:DB_CONNECTION="sqlite"
#     $env:DB_DATABASE="c:\xampp\htdocs\copart\database\database.sqlite"
#     php artisan migrate --force
#
#   Or:
#     copy .env.sqlite.example .env.sqlite
#     (use a dedicated .env.sqlite only if you load it yourself — Laravel reads .env by default)
#
# Keep your live MySQL .env as-is for production/tenant data work.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=sqlite
# Absolute path recommended on Windows; relative paths resolve from project root.
DB_DATABASE=database/database.sqlite
DB_FOREIGN_KEYS=true

# Leave MySQL vars unused while on sqlite (harmless if present):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
